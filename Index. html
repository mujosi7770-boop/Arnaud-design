<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Studio Photo & Design | L. NG Nzojibwami</title>
    <style>
        :root { --bg: #050505; --card-bg: #121212; --accent: #25d366; --text: #ffffff; }
        body { background: var(--bg); color: var(--text); font-family: sans-serif; margin: 0; padding-bottom: 100px; text-align: center; }
        header { padding: 50px 20px; background: linear-gradient(to bottom, #1a1a1a, var(--bg)); }
        h1 { letter-spacing: 5px; font-weight: 200; margin: 0; }
        
        .gallery { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 15px; padding: 15px; }
        .card { background: var(--card-bg); border-radius: 15px; overflow: hidden; border: 1px solid #222; }
        .card img { width: 100%; height: 400px; object-fit: cover; display: block; }
        .info { padding: 15px; }
        
        .btn { display: inline-block; padding: 12px 25px; border-radius: 30px; text-decoration: none; font-weight: bold; transition: 0.3s; }
        .btn-dl { background: #fff; color: #000; font-size: 0.8rem; margin-bottom: 10px; display: block; }
        .btn-wa { background: var(--accent); color: white; position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%); width: 80%; max-width: 300px; box-shadow: 0 4px 15px rgba(0,0,0,0.5); }
    </style>
</head>
<body>

    <header>
        <h1>NZ_DESIGN STUDIO</h1>
        <p style="opacity:0.5">PHOTOGRAPHIE • BURUNDI</p>
    </header>

    <main class="gallery" id="gallery">
        <div class="card">
            <img src="photos/photo1.jpg" alt="Shooting">
            <div class="info">
                <a href="photos/photo1.jpg" download class="btn btn-dl">TÉLÉCHARGER HD</a>
            </div>
        </div>

        <div class="card">
            <img src="photos/photo2.jpg" alt="Design">
            <div class="info">
                <a href="photos/photo2.jpg" download class="btn btn-dl">TÉLÉCHARGER HD</a>
            </div>
        </div>
    </main>

    <a href="https://wa.me/25765477584?text=Salut!%20Je%20viens%20de%20voir%20ton%20portfolio" class="btn btn-wa">
        RÉSERVER VIA WHATSAPP
    </a>

</body>
</html>
